CREATE DATABASE IF NOT EXISTS Escola;

 USE Escola;
 
 CREATE TABLE IF NOT EXISTS Aluno (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(1000) NOT NULL,
    idade int not null,
    turma int,
    nota1 decimal(4,2),
    nota2 decimal(4,2),
    nota3 decimal(4,2),
    soma decimal(4,2),
	media decimal(4,2),
	situacao varchar(1000)
 );
 
 select * from aluno