CREATE DATABASE IF NOT EXISTS Escola;

 USE Escola;
 
 CREATE TABLE IF NOT EXISTS Aluno (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    idade int not null,
    turma int,
	situacao_mat varchar(20),
	situacao_por varchar(20)
 );
 CREATE TABLE IF NOT EXISTS Matematica (
    id INT AUTO_INCREMENT PRIMARY KEY,
    aluno_id INT,
    nome VARCHAR(100) NOT NULL,
    turma int,
    nota1_mat decimal(4,2),
    nota2_mat decimal(4,2),
    nota3_mat decimal(4,2),
    soma_mat decimal(4,2),
	media_mat decimal(4,2),
	situacao_mat varchar(20),
    FOREIGN KEY (aluno_id) REFERENCES Aluno(id)
 );
 CREATE TABLE IF NOT EXISTS Portugues (
    id INT AUTO_INCREMENT PRIMARY KEY,
    aluno_id INT,
    nome VARCHAR(100) NOT NULL,
    turma int,
    nota1_por decimal(4,2),
    nota2_por decimal(4,2),
    nota3_por decimal(4,2),
    soma_por decimal(4,2),
	media_por decimal(4,2),
	situacao_por varchar(20),
    FOREIGN KEY (aluno_id) REFERENCES Aluno(id)
 );
